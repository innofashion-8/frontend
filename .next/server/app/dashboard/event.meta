{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/event/layout,_N_T_/dashboard/event/page,_N_T_/dashboard/event"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/event/__PAGE__",
    "/dashboard/event",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}